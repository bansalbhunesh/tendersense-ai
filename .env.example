# Root .env for `docker compose up`. Copy to .env and fill in.
#
# Backend hard-fails without these, so set them before bringing up the stack:
JWT_SECRET=replace-with-a-32-plus-character-random-string
ALLOWED_ORIGINS=http://localhost:5173

# Optional. Without it the AI service runs the deterministic-only path
# (still produces real PASS/FAIL verdicts; LLM cross-check disabled).
ANTHROPIC_API_KEY=

# Optional cache TTL knob.
EVALUATE_CACHE_TTL_SECONDS=900
