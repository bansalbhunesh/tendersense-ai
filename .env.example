# Root .env for `docker compose up`. Copy to .env and fill in.
#
# Backend hard-fails without these, so set them before bringing up the stack:
JWT_SECRET=replace-with-a-32-plus-character-random-string
ALLOWED_ORIGINS=http://localhost:5173

# Optional. Without it the AI service runs the deterministic-only path
# (still produces real PASS/FAIL verdicts; LLM cross-check disabled).
ANTHROPIC_API_KEY=

# Optional cache TTL knob.
EVALUATE_CACHE_TTL_SECONDS=900

# --- Bharat-first / sovereign-mode controls ---
# anthropic (default) | disabled (deterministic-only) | bhashini (translator only)
LLM_BACKEND=anthropic
# disabled (default) | bhashini  — pluggable translator for Indic-language tenders
TRANSLATION_BACKEND=disabled
# Tesseract language stack. Use eng+hin to enable Hindi OCR.
OCR_LANGS=eng
# Bhashini ULCA credentials — only required when TRANSLATION_BACKEND=bhashini
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=
BHASHINI_INFERENCE_URL=
