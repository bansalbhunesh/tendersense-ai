# Root .env for `docker compose up`. Copy to .env and fill in.
#
# --- Required for Docker Compose (backend validates at startup) ---
JWT_SECRET=replace-with-a-32-plus-character-random-string
# Access JWT lifetime (e.g. 15m, 1h). HttpOnly refresh cookie + Postgres refresh rows.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
ALLOWED_ORIGINS=http://localhost:5173
#
# --- Required only when running `go run .` in backend/ without Compose ---
# DATABASE_URL=postgres://tendersense:tendersense@localhost:5432/tendersense?sslmode=disable
# AI_SERVICE_URL=http://localhost:8081
# DATA_DIR=./data/uploads   # absolute path recommended; must match ai-service DATA_DIR for OCR paths
#
# Optional regex for Vercel *preview* URLs (gin-cors returns HTTP 403 if Origin does not match).
# Previews look like https://<project>-<deploymentId>-<team-slug>.vercel.app (not the same as production
# https://tendersense-ai.vercel.app). Put production origin(s) in ALLOWED_ORIGINS and add a regex for previews.
# Multiple patterns: separate with three pipe characters ||| (each fragment compiled separately).
# Example (replace YOUR_TEAM_SLUG):
# ALLOWED_ORIGIN_REGEX=^https://tendersense-[a-z0-9]+-YOUR_TEAM_SLUG\\.vercel\\.app$|||^https://tendersense-ai\\.vercel\\.app$
# If Render still returns HTTP 403 on register, set this until you tighten regex (not for strict production):
# CORS_ALLOW_VERCEL_PREVIEWS=true
# Password reset email (Resend)
RESEND_API_KEY=
RESET_EMAIL_FROM=TenderSense <no-reply@yourdomain.com>
APP_BASE_URL=http://localhost:5173
# Dev-only fallback: when true and email delivery fails, API returns reset_token in response.
ALLOW_INSECURE_RESET_TOKEN_RESPONSE=false

# Optional. Without it the AI service runs the deterministic-only path
# (still produces real PASS/FAIL verdicts; LLM cross-check disabled).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Per-request HTTP timeout (seconds) for Anthropic SDK calls (criteria + eval).
ANTHROPIC_TIMEOUT_SEC=120
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional cache TTL knobs (ai-service).
EVALUATE_CACHE_TTL_SECONDS=900
# Max JSON request body size (bytes) for POST/PUT bodies with Content-Length (default 32 MiB).
# MAX_JSON_BODY_BYTES=33554432

# Optional S3 / MinIO — when set, uploads are mirrored to the bucket and GET /api/v1/documents/:id/presign works.
# With `docker compose --profile objectstore up`, set MINIO_ROOT_PASSWORD in .env (required by compose; do not commit real secrets).
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=
# S3_ENDPOINT=minio:9000
# S3_USE_SSL=false
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=<same as MINIO_ROOT_PASSWORD when using MinIO root credentials in dev>
# S3_BUCKET=tendersense

# Parallel criterion×bidder workers in the AI evaluate endpoint (default 6).
# EVAL_PARALLEL_WORKERS=6
OCR_CACHE_TTL_SECONDS=86400
CRITERIA_CACHE_TTL_SECONDS=7200

# Shown on /api/v1/version and /v1/version when set (e.g. CI injects commit SHA).
GIT_SHA=

# --- Bharat-first / sovereign-mode controls ---
# anthropic (default) | groq | disabled (deterministic-only) | bhashini (translator only)
# Tip: use LLM_BACKEND=disabled when ANTHROPIC_API_KEY and GROQ_API_KEY are both unset (avoids noisy warnings).
LLM_BACKEND=anthropic
# disabled (default) | bhashini  — pluggable translator for Indic-language tenders
TRANSLATION_BACKEND=disabled
# Tesseract language stack. Use eng+hin to enable Hindi OCR.
OCR_LANGS=eng
# Bhashini ULCA credentials — only required when TRANSLATION_BACKEND=bhashini
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=
BHASHINI_INFERENCE_URL=
