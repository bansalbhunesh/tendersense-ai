DATABASE_URL=postgres://tendersense:tendersense@localhost:5432/tendersense?sslmode=disable
AI_SERVICE_URL=http://localhost:8081
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_ORIGIN_REGEX=
PORT=8080
# Absolute path recommended so the AI service sees the same path (shared volume in Docker).
DATA_DIR=data/uploads
# Optional: redis://localhost:6379/0 — AI service OCR/criteria cache (see docker-compose redis).
REDIS_URL=
JWT_SECRET=generate-a-long-random-string-for-production
RESEND_API_KEY=
RESET_EMAIL_FROM=TenderSense <no-reply@yourdomain.com>
APP_BASE_URL=http://localhost:5173
ALLOW_INSECURE_RESET_TOKEN_RESPONSE=true
MAX_PROCESS_TEXT_CHARS=500000
MAX_CRITERIA_TEXT_CHARS=400000
MAX_EVAL_CRITERIA=200
MAX_EVAL_BIDDERS=100
LLM_MAX_DOCS=8
LLM_MAX_CONTEXT_CHARS=180000
LLM_MAX_OUTPUT_TOKENS=2200
EVALUATE_CACHE_TTL_SECONDS=900
