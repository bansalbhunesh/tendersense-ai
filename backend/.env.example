DATABASE_URL=postgres://tendersense:tendersense@localhost:5432/tendersense?sslmode=disable
# Optional: only for `go test -tags=integration` — use a throwaway DB, not production (Render's DATABASE_URL is for the app only).
# TEST_DATABASE_URL=postgres://...
AI_SERVICE_URL=http://localhost:8081
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ALLOWED_ORIGINS=http://localhost:5173
# Optional: regex for extra origins (e.g. Vercel previews). Example:
# ALLOWED_ORIGIN_REGEX=^https://tendersense-ai(-[a-z0-9-]+)?\.vercel\.app$
ALLOWED_ORIGIN_REGEX=
PORT=8080
# Absolute path recommended so the AI service sees the same path (shared volume in Docker).
DATA_DIR=data/uploads
# Optional upload cap in bytes (default 52428800 = 50 MiB; align with gin MaxMultipartMemory).
MAX_UPLOAD_BYTES=
# Optional: shared Redis. AI service uses it for OCR/criteria cache; backend uses DB 1 in compose for eval rate limits.
REDIS_URL=
JWT_SECRET=generate-a-long-random-string-for-production
# Access JWT lifetime (default 15m). Longer values widen the XSS window for bearer tokens.
# JWT_ACCESS_TTL=15m
# HttpOnly refresh cookie: use REFRESH_COOKIE_SAMESITE=none + HTTPS when SPA and API are on different origins.
# REFRESH_COOKIE_SAMESITE=lax
# REFRESH_COOKIE_SECURE=
# With GIN_MODE=release, set REQUIRE_REDIS=true to refuse startup unless REDIS_URL is valid (multi-instance eval limits).
# REQUIRE_REDIS=false
RESEND_API_KEY=
RESET_EMAIL_FROM=TenderSense <no-reply@yourdomain.com>
APP_BASE_URL=http://localhost:5173
ALLOW_INSECURE_RESET_TOKEN_RESPONSE=true
MAX_PROCESS_TEXT_CHARS=500000
MAX_CRITERIA_TEXT_CHARS=400000
MAX_EVAL_CRITERIA=200
MAX_EVAL_BIDDERS=100
LLM_MAX_DOCS=8
LLM_MAX_CONTEXT_CHARS=180000
LLM_MAX_OUTPUT_TOKENS=2200
EVALUATE_CACHE_TTL_SECONDS=900
